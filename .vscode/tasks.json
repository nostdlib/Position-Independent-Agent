    {
      "label": "Run UEFI x86_64 (QEMU)",
      "type": "process",
      "command": "wsl",
      "args": [
        "--", "bash", "-lc",
        "cd \"$(wslpath '${workspaceFolder}')\" && qemu-system-x86_64 -bios /usr/share/ovmf/OVMF.fd -drive file=fat:rw:build/release/uefi/x86_64,format=raw,if=ide,index=0 -m 512 -nographic -nic user,model=e1000 -no-reboot"
      ],
      "dependsOn": "uefi-x86_64-release",
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Run UEFI aarch64 (QEMU)",
      "type": "process",
      "command": "wsl",
