        },
        {
            "name": "linux-i386",
            "compilerPath": "/usr/bin/clang",
            "intelliSenseMode": "linux-clang-x86",
            "cStandard": "c17",
            "cppStandard": "c++23",
            "defines": ["ARCHITECTURE_I386", "PLATFORM_LINUX", "PLATFORM_LINUX_I386", "ENABLE_LOGGING"],
            "includePath": ["${commonInclude}", "${workspaceFolder}/runtime/src/platform/os/linux", "${workspaceFolder}/runtime/src/platform/os/posix"]
