{
    "version": 4,
    "enableConfigurationSquiggles": true,
    "env": {
        "commonInclude": [
            "${workspaceFolder}/src",
            "${workspaceFolder}/runtime/src",
            "${workspaceFolder}/runtime/src/core",
            "${workspaceFolder}/runtime/src/core/algorithms",
            "${workspaceFolder}/runtime/src/core/compiler",
            "${workspaceFolder}/runtime/src/core/encoding",
            "${workspaceFolder}/runtime/src/core/io",
            "${workspaceFolder}/runtime/src/core/math",
            "${workspaceFolder}/runtime/src/core/memory",
            "${workspaceFolder}/runtime/src/core/string",
            "${workspaceFolder}/runtime/src/core/types",
            "${workspaceFolder}/runtime/src/core/types/embedded",
            "${workspaceFolder}/runtime/src/platform",
            "${workspaceFolder}/runtime/src/platform/io",
            "${workspaceFolder}/runtime/src/platform/fs",
            "${workspaceFolder}/runtime/src/platform/memory",
            "${workspaceFolder}/runtime/src/platform/network",
            "${workspaceFolder}/runtime/src/platform/os",
            "${workspaceFolder}/runtime/src/platform/system",
            "${workspaceFolder}/runtime/src/runtime",
            "${workspaceFolder}/runtime/src/runtime/crypto",
            "${workspaceFolder}/runtime/src/runtime/network",
            "${workspaceFolder}/runtime/src/runtime/network/dns",
            "${workspaceFolder}/runtime/src/runtime/network/http",
            "${workspaceFolder}/runtime/src/runtime/network/tls",
            "${workspaceFolder}/runtime/src/runtime/network/websocket"
        ]
    },
    "configurations": [
        {
            "name": "windows-i386",
            "compilerPath": "/usr/bin/clang",
            "intelliSenseMode": "windows-clang-x86",
            "cStandard": "c17",
            "cppStandard": "c++23",
            "defines": ["ARCHITECTURE_I386", "PLATFORM_WINDOWS", "PLATFORM_WINDOWS_I386", "ENABLE_LOGGING"],
            "includePath": ["${commonInclude}", "${workspaceFolder}/runtime/src/platform/os/windows"]
        },
        {
            "name": "windows-x86_64",
            "compilerPath": "/usr/bin/clang",
            "intelliSenseMode": "windows-clang-x64",
            "cStandard": "c17",
            "cppStandard": "c++23",
            "defines": ["ARCHITECTURE_X86_64", "PLATFORM_WINDOWS", "PLATFORM_WINDOWS_X86_64", "ENABLE_LOGGING"],
            "includePath": ["${commonInclude}", "${workspaceFolder}/runtime/src/platform/os/windows"]
        },
        {
            "name": "windows-aarch64",
            "compilerPath": "/usr/bin/clang",
            "intelliSenseMode": "windows-clang-arm64",
            "cStandard": "c17",
            "cppStandard": "c++23",
            "defines": ["ARCHITECTURE_AARCH64", "PLATFORM_WINDOWS", "PLATFORM_WINDOWS_AARCH64", "ENABLE_LOGGING"],
            "includePath": ["${commonInclude}", "${workspaceFolder}/runtime/src/platform/os/windows"]
        },
        {
